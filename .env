# =========================
# Core
# =========================
BASE_URL=http://192.168.1.20:5555
SOCKET_URL=http://192.168.1.20:5555
PORT=5555
API_PREFIX=/api

# =========================
# Network / HTTP
# =========================
HTTP_TIMEOUT_SECONDS=30
FORCE_ANDROID_EMULATOR=0
DEBUG_LOGS=1

# =========================
# Google Maps Platform
# =========================
GOOGLE_MAPS_API_KEY=PUT_YOUR_GOOGLE_MAPS_API_KEY_HERE
GOOGLE_MAPS_KEY=PUT_YOUR_GOOGLE_MAPS_API_KEY_HERE
GOOGLE_DIRECTIONS_KEY=PUT_YOUR_GOOGLE_DIRECTIONS_KEY_HERE
GOOGLE_PLACES_KEY=PUT_YOUR_GOOGLE_PLACES_KEY_HERE

# =========================
# App Flags / Debug
# =========================
FAKE_SEARCH_MODE=0
FAKE_ASSIGN_SECONDS=6

# =========================
# Tracking / Maps
# =========================
ROUTE_REFRESH_SECONDS=6
CAMERA_THROTTLE_MS=250
TECH_LOCATION_THROTTLE_MS=800

ARRIVAL_DISTANCE_METERS=40
ARRIVAL_STABLE_SECONDS=6

TRAIL_MAX_POINTS=160
TRAIL_MIN_ADD_MS=700
TRAIL_MIN_MOVE_METERS=8

ROUTE_FLOW_EVERY_N=6
ROUTE_MIN_MOVE_METERS=18

FOLLOW_RESUME_DELAY_MS=3500