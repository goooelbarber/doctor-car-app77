# =========================
# Core
# =========================

# ✅ ApiService بيقرأ BASE_URL (مش API_BASE_URL)
BASE_URL=http://192.168.1.12:5555

# ✅ لو السيرفر عنده prefix /api (لو endpoints عندك /api/users ... الخ)
# لو endpoints عندك من غير /api خليها فاضية: API_PREFIX=
API_PREFIX=/api

SOCKET_URL=http://192.168.1.12:5555

# =========================
# Orders (Road services)
# =========================

# ✅ عدّلهم حسب الباك إند عندك
# غالبًا:
ORDER_CREATE_PATH=/orders
ORDER_MY_PATH=/orders

# =========================
# Network / HTTP
# =========================
HTTP_TIMEOUT_SECONDS=18
FORCE_ANDROID_EMULATOR=0

# اظهار Logs إضافية (1/0)
DEBUG_LOGS=1

# =========================
# Google Maps Platform
# =========================
GOOGLE_MAPS_KEY=AIzaSyD9BGSScE-DU9nbdFgIbJV4fbNspNdPg_M
GOOGLE_DIRECTIONS_KEY=${GOOGLE_MAPS_KEY}
GOOGLE_PLACES_KEY=${GOOGLE_MAPS_KEY}

# =========================
# App Flags / Debug
# =========================
FAKE_SEARCH_MODE=0
FAKE_ASSIGN_SECONDS=6

# throttle لتحديثات الـ route (بالثواني) داخل Tracking
ROUTE_REFRESH_SECONDS=6

# throttle لتحريك الكاميرا (ms) داخل Tracking
CAMERA_THROTTLE_MS=250

# throttle لإرسال موقع الفني (ms) لو هتبعت من تطبيق الفني
TECH_LOCATION_THROTTLE_MS=800