# =========================
# Tracking / Maps
# =========================

# throttle لتحديثات الـ route (بالثواني) داخل Tracking
ROUTE_REFRESH_SECONDS=6

# throttle لتحريك الكاميرا (ms) داخل Tracking
CAMERA_THROTTLE_MS=250

# throttle لإرسال موقع الفني (ms) لو هتبعت من تطبيق الفني
TECH_LOCATION_THROTTLE_MS=800

# يعتبر الفني وصل لو دخل داخل هذا النطاق
ARRIVAL_DISTANCE_METERS=40

# عدد الثواني التي يظل فيها الفني داخل نطاق الوصول قبل اعتبار الحالة "وصل"
ARRIVAL_STABLE_SECONDS=6

# أقصى عدد نقاط لتريل حركة الفني
TRAIL_MAX_POINTS=160

# أقل مدة بين إضافة نقطة trail والأخرى
TRAIL_MIN_ADD_MS=700

# أقل مسافة لإضافة نقطة جديدة في trail
TRAIL_MIN_MOVE_METERS=8

# كل كام نقطة نعمل sampling للـ route flow effect
ROUTE_FLOW_EVERY_N=6

# أقل حركة للفني قبل ما نطلب route جديد
ROUTE_MIN_MOVE_METERS=18

# بعد ما المستخدم يحرك الخريطة يدويًا، ننتظر هذا الوقت قبل ما follow يرجع يتحكم
FOLLOW_RESUME_DELAY_MS=3500